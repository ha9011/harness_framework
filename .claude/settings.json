{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)/harness\" && npm run --if-present lint 2>&1 && npm run --if-present build 2>&1 && npm run --if-present test 2>&1"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.claude/hooks/block-dangerous-bash.js\""
          }
        ]
      }
    ]
  }
}
